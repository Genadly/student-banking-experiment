<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - InvestBank</title>
    <link rel="stylesheet" href="~/css/variables.css">
    <link rel="stylesheet" href="~/styles.css">
</head>

<body>
    <header class="header">
        <div class="container">
            <div class="navbar">
                <div class="logo">InvestBank</div>
                <div class="nav-links">
                    <button class="btn-outline" id="loginBtn">Вход</button>
                    <button class="btn-primary" id="registerBtn">Регистрация</button>
                </div>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div>© 2026 InvestBank. Все права защищены.</div>
                <div>📞 375-29-123-45-67</div>
                <div>✉️ support@InvestBank.ru</div>
            </div>
            <div class="footer-copyright">Интернет-банк Лицензия ЦБ РБ № 1234</div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>